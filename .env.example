# Copy to .env and fill in. Never commit .env.

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional paths (defaults: data/processed/...)
# DATA_PATH=
# SQLITE_PATH=

# Dev server (run_dev.py). Default 8765 — Windows often blocks 8000.
# PORT=8765
# HOST=127.0.0.1

# Recommendation tuning
# MAX_CANDIDATES_LLM=25
# QUERY_CANDIDATE_LIMIT=200
